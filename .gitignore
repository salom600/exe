# Git Ignore for FlowCut

# Rust build artifacts
src-tauri/target/
**/*.rs.bk

# Node.js
node_modules/
npm-debug.log*

# OS artifacts
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.iml

# Build output (keep bundle dir but ignore intermediates)
src-tauri/target/debug/
src-tauri/target/release/deps/
src-tauri/target/release/build/
src-tauri/target/release/.fingerprint/

# Environment
.env
.env.local

# Temporary files
*.tmp
*.bak
